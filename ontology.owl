        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Identifier of the corrective action.</rdfs:comment>
        <rdfs:label>FSCA id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#imdrfCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>IMDRF code related with the type of risk.</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#incidentDescription -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#incidentDescription">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the incident.</rdfs:comment>
        <rdfs:label>Incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#incidentId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#incidentId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Identifier of the incident in the dataset.</rdfs:comment>
        <rdfs:label>incident id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#intendedPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Intended medical purpose of the device.</rdfs:comment>
        <rdfs:label>intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is active.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#isIVD">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
