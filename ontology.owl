    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/PEC2#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#actionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the corrective action was initiated.</rdfs:comment>
        <rdfs:label>action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#actionDescription -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#actionDescription">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the corrective action.</rdfs:comment>
        <rdfs:label>action description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#authorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Authorization of the manufacturer.</rdfs:comment>
        <rdfs:label>authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#closureDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#closureDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the incident or corrective action was closed.</rdfs:comment>
        <rdfs:label>closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#competentAuthority -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#competentAuthority">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Regulatory authority responsible for overseeing the incident or action.</rdfs:comment>
        <rdfs:label>competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#contactEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label>contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#correctiveActionTaken">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates  whether a corrective action was taken.</rdfs:comment>
        <rdfs:label>corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#countriesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#countriesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Information of the geographic scope affected by the corrective action.</rdfs:comment>
        <rdfs:label>countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#detectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#detectionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the issue or incident was first detected.</rdfs:comment>
        <rdfs:label>detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#deviceId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#deviceId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Identifier of the device (in the dataset).</rdfs:comment>
        <rdfs:label>device id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#deviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Name of the medical device.</rdfs:comment>
        <rdfs:label>device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#devicesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Number or textual description of devices affected by the corrective action.</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#eudamedFSCARef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#eudamedFSCARef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Reference identifier of the corrective action in the EUDAMED system.</rdfs:comment>
        <rdfs:label>EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#eudamedIncidentRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Reference identifier of the incident in the EUDAMED system.</rdfs:comment>
        <rdfs:label>eudamed incident ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#eudamedSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Identifier assigned to the manufacturer in EUDAMED</rdfs:comment>
        <rdfs:label>EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the incident event occurred.</rdfs:comment>
        <rdfs:label>event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/PEC2#fscaId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#fscaId">
