        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Name or description of the risk.</rdfs:comment>
