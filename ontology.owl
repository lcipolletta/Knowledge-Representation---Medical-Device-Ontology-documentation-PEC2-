<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/PEC2#"
     xml:base="http://www.uoc.edu/PEC2"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:PEC2="http://www.uoc.edu/PEC2#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.uoc.edu/PEC2">
        <dc:description>Ontology for modelling incidents, risks and corrective actions in medical devices.</dc:description>
        <dc:title>Medical Device Risk Ontology</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <rdfs:label>Medical Device Risk Ontology</rdfs:label>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</owl:versionInfo>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- https://w3id.org/mod#createdWith -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/mod#createdWith"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/PEC2#hasActionType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasActionType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#ActionType"/>
        <rdfs:comment>Links a corrective action to its action type.</rdfs:comment>
        <rdfs:label>has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasAffectedDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasAffectedDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#DeviceType"/>
        <rdfs:comment>Links a risk to the type of device affected by that risk.</rdfs:comment>
        <rdfs:label>has affected device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasCountry -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasCountry">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Country"/>
        <rdfs:comment>Links a manufacturer to the country where it is located or registered</rdfs:comment>
        <rdfs:label>has country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasDevice -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasDevice">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:comment>Links an incident to the device involved in the incident</rdfs:comment>
        <rdfs:label>has device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#DeviceType"/>
        <rdfs:comment>Links a device to its device type.</rdfs:comment>
        <rdfs:label>has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasIncident -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasIncident">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:comment>Links a corrective action to the incident that motivated it.</rdfs:comment>
        <rdfs:label>has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasIncidentType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasIncidentType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#IncidentType"/>
        <rdfs:comment>Links an incident to its incident type.</rdfs:comment>
        <rdfs:label>has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:comment>Links a device to its manufacturer.</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasProbability -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasProbability">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Probability"/>
        <rdfs:comment>Links a risk to its probability level.</rdfs:comment>
        <rdfs:label>has probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#RegulatoryFramework"/>
        <rdfs:comment>Links a device to its applicable regulatory framework</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:comment>Links an incident to an associated risk.</rdfs:comment>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasRiskCategory">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#RiskCategory"/>
        <rdfs:comment>Links a risk to its high-level risk category.</rdfs:comment>
        <rdfs:label>has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#RiskClass"/>
        <rdfs:comment>Links a device to its regulatory risk class</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasRiskType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasRiskType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#RiskType"/>
        <rdfs:comment>Links a risk to its specific risk type.</rdfs:comment>
        <rdfs:label>has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasSeverity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Severity"/>
        <rdfs:comment>Links a risk to its severity level.</rdfs:comment>
        <rdfs:label>has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#hasStatus -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Status"/>
        <rdfs:comment>Links a corrective action to its current status.</rdfs:comment>
        <rdfs:label>has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#reportedBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
        <rdfs:comment>Links an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2#reportedInCountry">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2#Country"/>
        <rdfs:comment>Links an incident to the countries where it was reported.</rdfs:comment>
        <rdfs:label>reported in country</rdfs:label>
    </owl:ObjectProperty>
    


