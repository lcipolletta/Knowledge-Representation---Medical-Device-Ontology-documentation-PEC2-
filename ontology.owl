    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/PEC2#ActionType -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#ActionType">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Type of action performed in response to an incident.</rdfs:comment>
        <rdfs:label>Action Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#ClassIIIDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#ClassIIIDevice">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#Device"/>
        <rdfs:comment>Device inferred as belonging to risk class III.</rdfs:comment>
        <rdfs:label>Class III device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#ClosedCorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#ClosedCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:comment>Corrective action inferred as closed based on its status.</rdfs:comment>
        <rdfs:label>Closed corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#CorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasStatus"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/PEC2#Status"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Action taken to mitigate or solve a safety issue related to a device</rdfs:comment>
        <rdfs:label>Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Country -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Country">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Country associated with a manufacturer or where an incident is reported.</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#CriticalRiskIncident -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#CriticalRiskIncident">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#Incident"/>
        <rdfs:comment>Incident inferred as critical based on the severity of its associated risk.</rdfs:comment>
        <rdfs:label>Critical Risk Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Device -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Device">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasDeviceType"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/PEC2#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasDeviceType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/PEC2#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/PEC2#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Medical device</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#DeviceRelatedRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#DeviceRelatedRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#RiskType"/>
        <rdfs:comment>Risk type associated with device malfunction or failure</rdfs:comment>
        <rdfs:label>Device Related Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#DeviceRiskCategory -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#DeviceRiskCategory">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#RiskCategory"/>
        <rdfs:comment>Risk category related to device malfunction, performance or safety.</rdfs:comment>
        <rdfs:label>Device Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#DeviceType -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Category describing the type of medical device.</rdfs:comment>
        <rdfs:label>Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#HumanRelatedRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#HumanRelatedRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#RiskType"/>
        <rdfs:comment>Risk type associated with harm to humans caused by device-related issues.</rdfs:comment>
        <rdfs:label>Human Related Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#HumanRiskCategory -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#HumanRiskCategory">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#RiskCategory"/>
        <rdfs:comment>Risk category related to harm or impact on humans.</rdfs:comment>
        <rdfs:label>Human Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Incident -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Incident">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Event involving a device that may lead to patient harm or malfunction.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#IncidentType -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#IncidentType">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Classification of incidents</rdfs:comment>
        <rdfs:label>Incident Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Manufacturer -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Organization that produces and assembles medical devices</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity">
        <rdfs:comment>Root class for the main entities represented in the medical device risk ontology.</rdfs:comment>
        <rdfs:label>Medical Device Ontology Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#OpenCorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#OpenCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#CorrectiveAction"/>
        <rdfs:comment>Corrective action inferred as open based on its status.</rdfs:comment>
        <rdfs:label>Open corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Probability -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Probability">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Likelihood that a risk will occur.</rdfs:comment>
        <rdfs:label>Probability</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#RegulatoryFramework -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Regulatory system under which a device is classified (MDR, IVDR).</rdfs:comment>
        <rdfs:label>Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Risk -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Risk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/PEC2#hasSeverity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/PEC2#Severity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Potential hazard associated with a medical device or its use</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#RiskCategory -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#RiskCategory">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Classification of risks based on their impact domain.</rdfs:comment>
        <rdfs:label>Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#RiskClass -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Regulatory classification level assigned to a medical device</rdfs:comment>
        <rdfs:label>Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#RiskType -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#RiskType">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Type of risk based on its cause or nature.</rdfs:comment>
        <rdfs:label>Risk Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Severity -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Severity">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Level of seriousness of a risk or incident</rdfs:comment>
        <rdfs:label>Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/PEC2#Status -->


    <owl:Class rdf:about="http://www.uoc.edu/PEC2#Status">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity"/>
        <rdfs:comment>Current state of a corrective action</rdfs:comment>
        <rdfs:label>Status</rdfs:label>
    </owl:Class>
    


