    <!-- http://www.uoc.edu/PEC2#scope -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/PEC2#scope">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
