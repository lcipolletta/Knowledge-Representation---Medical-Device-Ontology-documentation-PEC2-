@prefix : <http://www.uoc.edu/PEC2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.uoc.edu/PEC2#> .

<http://www.uoc.edu/PEC2> rdf:type owl:Ontology ;
                           <http://purl.org/dc/elements/1.1/description> "Ontology for modelling incidents, risks and corrective actions in medical devices." ;
                           <http://purl.org/dc/elements/1.1/title> "Medical Device Risk Ontology" ;
                           <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                           rdfs:label "Medical Device Risk Ontology" ;
                           owl:versionInfo 1.0 ;
                           <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/license
<http://purl.org/dc/elements/1.1/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/PEC2#hasActionType
:hasActionType rdf:type owl:ObjectProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :ActionType ;
               rdfs:comment "Links a corrective action to its action type." ;
               rdfs:label "has action type" .


###  http://www.uoc.edu/PEC2#hasAffectedDeviceType
:hasAffectedDeviceType rdf:type owl:ObjectProperty ;
                       rdfs:domain :Risk ;
                       rdfs:range :DeviceType ;
                       rdfs:comment "Links a risk to the type of device affected by that risk." ;
                       rdfs:label "has affected device type" .


###  http://www.uoc.edu/PEC2#hasCountry
:hasCountry rdf:type owl:ObjectProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range :Country ;
            rdfs:comment "Links a manufacturer to the country where it is located or registered" ;
            rdfs:label "has country" .


###  http://www.uoc.edu/PEC2#hasDevice
:hasDevice rdf:type owl:ObjectProperty ;
           rdfs:domain :Incident ;
           rdfs:range :Device ;
           rdfs:comment "Links an incident to the device involved in the incident" ;
           rdfs:label "has device" .


###  http://www.uoc.edu/PEC2#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Links a device to its device type." ;
               rdfs:label "has device type" .


###  http://www.uoc.edu/PEC2#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range :Incident ;
             rdfs:comment "Links a corrective action to the incident that motivated it." ;
             rdfs:label "has incident" .


###  http://www.uoc.edu/PEC2#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :IncidentType ;
                 rdfs:comment "Links an incident to its incident type." ;
                 rdfs:label "has incident type" .


###  http://www.uoc.edu/PEC2#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Links a device to its manufacturer." ;
                 rdfs:label "has manufacturer" .


###  http://www.uoc.edu/PEC2#hasProbability
:hasProbability rdf:type owl:ObjectProperty ;
                rdfs:domain :Risk ;
                rdfs:range :Probability ;
                rdfs:comment "Links a risk to its probability level." ;
                rdfs:label "has probability" .


###  http://www.uoc.edu/PEC2#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range :RegulatoryFramework ;
                        rdfs:comment "Links a device to its applicable regulatory framework" ;
                        rdfs:label "has regulatory framework" .


###  http://www.uoc.edu/PEC2#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Links an incident to an associated risk." ;
         rdfs:label "has risk" .


###  http://www.uoc.edu/PEC2#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Links a risk to its high-level risk category." ;
                 rdfs:label "has risk category" .


###  http://www.uoc.edu/PEC2#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Links a device to its regulatory risk class" ;
              rdfs:label "has risk class" .


###  http://www.uoc.edu/PEC2#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             rdfs:comment "Links a risk to its specific risk type." ;
             rdfs:label "has risk type" .


###  http://www.uoc.edu/PEC2#hasSeverity
:hasSeverity rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Risk ;
             rdfs:range :Severity ;
             rdfs:comment "Links a risk to its severity level." ;
             rdfs:label "has severity" .


###  http://www.uoc.edu/PEC2#hasStatus
:hasStatus rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range :Status ;
           rdfs:comment "Links a corrective action to its current status." ;
           rdfs:label "has status" .


###  http://www.uoc.edu/PEC2#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Links an incident to the manufacturer that reported it." ;
            rdfs:label "reported by" .


###  http://www.uoc.edu/PEC2#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country ;
                   rdfs:comment "Links an incident to the countries where it was reported." ;
                   rdfs:label "reported in country" .


#################################################################
#    Data properties
#################################################################

###  http://www.uoc.edu/PEC2#actionDate
:actionDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :CorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "Date when the corrective action was initiated." ;
            rdfs:label "action date" .


###  http://www.uoc.edu/PEC2#actionDescription
:actionDescription rdf:type owl:DatatypeProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Description of the corrective action." ;
                   rdfs:label "action description" .


###  http://www.uoc.edu/PEC2#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Authorization of the manufacturer." ;
                     rdfs:label "authorization number" .


###  http://www.uoc.edu/PEC2#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "Date when the incident or corrective action was closed." ;
             rdfs:label "closure date" .


###  http://www.uoc.edu/PEC2#competentAuthority
:competentAuthority rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Manufacturer ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Regulatory authority responsible for overseeing the incident or action." ;
                    rdfs:label "competent authority" .


###  http://www.uoc.edu/PEC2#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Contact email address of the manufacturer." ;
              rdfs:label "contact email" .


###  http://www.uoc.edu/PEC2#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Indicates  whether a corrective action was taken." ;
                       rdfs:label "corrective action taken" .


###  http://www.uoc.edu/PEC2#countriesAffected
:countriesAffected rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Information of the geographic scope affected by the corrective action." ;
                   rdfs:label "countries affected" .


###  http://www.uoc.edu/PEC2#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date when the issue or incident was first detected." ;
               rdfs:label "detection date" .


###  http://www.uoc.edu/PEC2#deviceId
:deviceId rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "Identifier of the device (in the dataset)." ;
          rdfs:label "device id" .


###  http://www.uoc.edu/PEC2#deviceName
:deviceName rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "Name of the medical device." ;
            rdfs:label "device name" .


###  http://www.uoc.edu/PEC2#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Number or textual description of devices affected by the corrective action." ;
                 rdfs:label "devices affected" .


###  http://www.uoc.edu/PEC2#eudamedFSCARef
:eudamedFSCARef rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "Reference identifier of the corrective action in the EUDAMED system." ;
                rdfs:label "EUDAMED FSCA reference" .


###  http://www.uoc.edu/PEC2#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Reference identifier of the incident in the EUDAMED system." ;
                    rdfs:label "eudamed incident ref" .


###  http://www.uoc.edu/PEC2#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "Identifier assigned to the manufacturer in EUDAMED" ;
            rdfs:label "EUDAMED SRN" .


###  http://www.uoc.edu/PEC2#eventDate
:eventDate rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "Date when the incident event occurred." ;
           rdfs:label "event date" .


###  http://www.uoc.edu/PEC2#fscaId
:fscaId rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :CorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "Identifier of the corrective action." ;
        rdfs:label "FSCA id" .


###  http://www.uoc.edu/PEC2#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "IMDRF code related with the type of risk." ;
           rdfs:label "IMDRF code" .


###  http://www.uoc.edu/PEC2#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Description of the incident." ;
                     rdfs:label "Incident description" .


###  http://www.uoc.edu/PEC2#incidentId
:incidentId rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Identifier of the incident in the dataset." ;
            rdfs:label "incident id" .


###  http://www.uoc.edu/PEC2#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Intended medical purpose of the device." ;
                 rdfs:label "intended purpose" .


###  http://www.uoc.edu/PEC2#isActive
:isActive rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device is active." ;
          rdfs:label "is active" .


###  http://www.uoc.edu/PEC2#isIVD
:isIVD rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device." ;
       rdfs:label "is IVD" .


###  http://www.uoc.edu/PEC2#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is implantable." ;
               rdfs:label "is implantable" .


###  http://www.uoc.edu/PEC2#isReusable
:isReusable rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device can be reused." ;
            rdfs:label "is reusable" .


###  http://www.uoc.edu/PEC2#manufacturerId
:manufacturerId rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "Identifier of the manufacturer in the dataset." ;
                rdfs:label "manufacturer id" .


###  http://www.uoc.edu/PEC2#name
:name rdf:type owl:DatatypeProperty ,
               owl:FunctionalProperty ;
      rdfs:domain :Manufacturer ;
      rdfs:range xsd:string ;
      rdfs:comment "Name of the manufacturer." ;
      rdfs:label "name" .


###  http://www.uoc.edu/PEC2#outcome
:outcome rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Outcome or consequence of the incident." ;
         rdfs:label "outcome" .


###  http://www.uoc.edu/PEC2#patientAge
:patientAge rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Patient age as represented in the source dataset, including non-numeric values when applicable." ;
            rdfs:label "patient age" .


###  http://www.uoc.edu/PEC2#patientSex
:patientSex rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Sex of the patient involved in the incident." ;
            rdfs:label "patient sex" .


###  http://www.uoc.edu/PEC2#reportDate
:reportDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Date when the incident was reported." ;
            rdfs:label "report date" .


###  http://www.uoc.edu/PEC2#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Description of the risk." ;
                 rdfs:label "Risk description" .


###  http://www.uoc.edu/PEC2#riskId
:riskId rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :Risk ;
        rdfs:range xsd:string ;
        rdfs:comment "Identifier of the risk in the dataset." ;
        rdfs:label "risk id" .


###  http://www.uoc.edu/PEC2#riskName
:riskName rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "Name or description of the risk." ;
          rdfs:label "risk name" .


###  http://www.uoc.edu/PEC2#scope
:scope rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :CorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "Scope of the corrective action or incident." ;
       rdfs:label "scope" .


###  http://www.uoc.edu/PEC2#udiDi
:udiDi rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "Unique Device Identification." ;
       rdfs:label "udi di" .


#################################################################
#    Classes
#################################################################

###  http://www.uoc.edu/PEC2#ActionType
:ActionType rdf:type owl:Class ;
            rdfs:subClassOf :MedicalDeviceOntologyEntity ;
            rdfs:comment "Type of action performed in response to an incident." ;
            rdfs:label "Action Type" .


###  http://www.uoc.edu/PEC2#ClassIIIDevice
:ClassIIIDevice rdf:type owl:Class ;
                rdfs:subClassOf :Device ;
                rdfs:comment "Device inferred as belonging to risk class III." ;
                rdfs:label "Class III device" .


###  http://www.uoc.edu/PEC2#ClosedCorrectiveAction
:ClosedCorrectiveAction rdf:type owl:Class ;
                        rdfs:subClassOf :CorrectiveAction ;
                        rdfs:comment "Corrective action inferred as closed based on its status." ;
                        rdfs:label "Closed corrective action" .


###  http://www.uoc.edu/PEC2#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf :MedicalDeviceOntologyEntity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasStatus ;
                                    owl:someValuesFrom :Status
                                  ] ;
                  rdfs:comment "Action taken to mitigate or solve a safety issue related to a device" ;
                  rdfs:label "Corrective Action" .


###  http://www.uoc.edu/PEC2#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :MedicalDeviceOntologyEntity ;
         rdfs:comment "Country associated with a manufacturer or where an incident is reported." ;
         rdfs:label "Country" .


###  http://www.uoc.edu/PEC2#CriticalRiskIncident
:CriticalRiskIncident rdf:type owl:Class ;
                      rdfs:subClassOf :Incident ;
                      rdfs:comment "Incident inferred as critical based on the severity of its associated risk." ;
                      rdfs:label "Critical Risk Incident" .


###  http://www.uoc.edu/PEC2#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf :MedicalDeviceOntologyEntity ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDeviceType ;
                          owl:someValuesFrom :DeviceType
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:someValuesFrom :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDeviceType ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :DeviceType
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ;
        rdfs:comment "Medical device" ;
        rdfs:label "Device" .


###  http://www.uoc.edu/PEC2#DeviceRelatedRisk
:DeviceRelatedRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType ;
                   rdfs:comment "Risk type associated with device malfunction or failure" ;
                   rdfs:label "Device Related Risk" .


###  http://www.uoc.edu/PEC2#DeviceRiskCategory
:DeviceRiskCategory rdf:type owl:Class ;
                    rdfs:subClassOf :RiskCategory ;
                    rdfs:comment "Risk category related to device malfunction, performance or safety." ;
                    rdfs:label "Device Risk Category" .


###  http://www.uoc.edu/PEC2#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:subClassOf :MedicalDeviceOntologyEntity ;
            rdfs:comment "Category describing the type of medical device." ;
            rdfs:label "Device Type" .


###  http://www.uoc.edu/PEC2#HumanRelatedRisk
:HumanRelatedRisk rdf:type owl:Class ;
                  rdfs:subClassOf :RiskType ;
                  rdfs:comment "Risk type associated with harm to humans caused by device-related issues." ;
                  rdfs:label "Human Related Risk" .


###  http://www.uoc.edu/PEC2#HumanRiskCategory
:HumanRiskCategory rdf:type owl:Class ;
                   rdfs:subClassOf :RiskCategory ;
                   rdfs:comment "Risk category related to harm or impact on humans." ;
                   rdfs:label "Human Risk Category" .


###  http://www.uoc.edu/PEC2#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalDeviceOntologyEntity ;
          rdfs:comment "Event involving a device that may lead to patient harm or malfunction." ;
          rdfs:label "Incident" .


###  http://www.uoc.edu/PEC2#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDeviceOntologyEntity ;
              rdfs:comment "Classification of incidents" ;
              rdfs:label "Incident Type" .


###  http://www.uoc.edu/PEC2#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDeviceOntologyEntity ;
              rdfs:comment "Organization that produces and assembles medical devices" ;
              rdfs:label "Manufacturer" .


###  http://www.uoc.edu/PEC2#MedicalDeviceOntologyEntity
:MedicalDeviceOntologyEntity rdf:type owl:Class ;
                             rdfs:comment "Root class for the main entities represented in the medical device risk ontology." ;
                             rdfs:label "Medical Device Ontology Entity" .


###  http://www.uoc.edu/PEC2#OpenCorrectiveAction
:OpenCorrectiveAction rdf:type owl:Class ;
                      rdfs:subClassOf :CorrectiveAction ;
                      rdfs:comment "Corrective action inferred as open based on its status." ;
                      rdfs:label "Open corrective action" .


###  http://www.uoc.edu/PEC2#Probability
:Probability rdf:type owl:Class ;
             rdfs:subClassOf :MedicalDeviceOntologyEntity ;
             rdfs:comment "Likelihood that a risk will occur." ;
             rdfs:label "Probability" .


###  http://www.uoc.edu/PEC2#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:subClassOf :MedicalDeviceOntologyEntity ;
                     rdfs:comment "Regulatory system under which a device is classified (MDR, IVDR)." ;
                     rdfs:label "Regulatory Framework" .


###  http://www.uoc.edu/PEC2#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf :MedicalDeviceOntologyEntity ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasSeverity ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Severity
                      ] ;
      rdfs:comment "Potential hazard associated with a medical device or its use" ;
      rdfs:label "Risk" .


###  http://www.uoc.edu/PEC2#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDeviceOntologyEntity ;
              rdfs:comment "Classification of risks based on their impact domain." ;
              rdfs:label "Risk Category" .


###  http://www.uoc.edu/PEC2#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:subClassOf :MedicalDeviceOntologyEntity ;
           rdfs:comment "Regulatory classification level assigned to a medical device" ;
           rdfs:label "Risk Class" .


###  http://www.uoc.edu/PEC2#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:subClassOf :MedicalDeviceOntologyEntity ;
          rdfs:comment "Type of risk based on its cause or nature." ;
          rdfs:label "Risk Type" .


###  http://www.uoc.edu/PEC2#Severity
:Severity rdf:type owl:Class ;
          rdfs:subClassOf :MedicalDeviceOntologyEntity ;
          rdfs:comment "Level of seriousness of a risk or incident" ;
          rdfs:label "Severity" .


###  http://www.uoc.edu/PEC2#Status
:Status rdf:type owl:Class ;
        rdfs:subClassOf :MedicalDeviceOntologyEntity ;
