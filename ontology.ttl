###  http://www.uoc.edu/PEC2#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasActionType :SafetyAlert ;
          :hasIncident :INC-001 ;
          :hasStatus :Open ;
          :actionDate "2024-02-01"^^xsd:date ;
          :actionDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "850" ;
          :eudamedFSCARef "EU-FSCA-2024-000001" ;
          :fscaId "FSCA-001" ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Instance of a corrective action from the dataset." ;
          rdfs:label "FSCA-001" .


###  http://www.uoc.edu/PEC2#FSCA-002
:FSCA-002 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasActionType :Recall ;
          :hasIncident :INC-002 ;
          :hasStatus :Closed ;
          :actionDate "2024-02-28"^^xsd:date ;
          :actionDescription "Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced." ;
          :closureDate "2024-05-31"^^xsd:date ;
          :countriesAffected "EU-wide + UK" ;
          :devicesAffected "1240" ;
          :eudamedFSCARef "EU-FSCA-2024-000002" ;
          :fscaId "FSCA-002" ;
          :scope "Micra AV lots manufactured between 2022-09 and 2023-03" ;
          rdfs:comment "Instance of a corrective action from the dataset." ;
          rdfs:label "FSCA-002" .


###  http://www.uoc.edu/PEC2#FSCA-003
:FSCA-003 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasActionType :InSituCorrection ;
          :hasIncident :INC-003 ;
          :hasStatus :Closed ;
          :actionDate "2024-03-15"^^xsd:date ;
          :actionDescription "Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres." ;
          :closureDate "2024-06-30"^^xsd:date ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "320" ;
          :eudamedFSCARef "EU-FSCA-2024-000003" ;
          :fscaId "FSCA-003" ;
          :scope "Portico THV sizes 23mm and 25mm from lots before 2023-11" ;
          rdfs:comment "Instance of a corrective action from the dataset." ;
          rdfs:label "FSCA-003" .


